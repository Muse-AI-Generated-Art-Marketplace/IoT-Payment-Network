{
  "name": "@iot-stellar/api",
  "version": "1.0.0",
  "description": "TypeScript/Node.js backend API for IoT Payment & DID on Stellar Network",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "stellar",
    "soroban",
    "api",
    "backend",
    "nodejs",
    "typescript",
    "iot",
    "did"
  ],
  "author": "Your Team",
  "license": "MIT",
  "dependencies": {
    "@iot-stellar/identity": "workspace:*",
    "@stellar/stellar-sdk": "^12.0.0",
    "@stellar/soroban-sdk": "^20.0.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.0.0",
    "joi": "^17.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "prisma": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "redis": "^4.0.0",
    "ws": "^8.0.0",
    "socket.io": "^4.0.0",
    "axios": "^1.0.0",
    "winston": "^3.0.0",
    "rate-limiter-flexible": "^2.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/morgan": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/ws": "^8.0.0",
    "@types/jest": "^29.0.0",
    "@types/compression": "^1.7.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "supertest": "^6.0.0",
    "@types/supertest": "^2.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts"
    ]
  }
}
